import shlex
import shutil
import subprocess
from pathlib import Path

import yaml


def _has_nvidia_gpu() -> bool:
    if shutil.which("nvidia-smi") is None:
        return False
    try:
        out = subprocess.check_output(["nvidia-smi", "-L"], stderr=subprocess.STDOUT, text=True).strip()
        return bool(out)
    except Exception:
        return False


def _load_bayesdream_cfg(path: Path) -> dict:
    if not path.exists():
        raise FileNotFoundError(f"bayesdream config not found: {path}")
    with path.open("r", encoding="utf-8") as f:
        cfg = yaml.safe_load(f) or {}
    if not isinstance(cfg, dict):
        raise ValueError("bayesdream config root must be a YAML mapping")
    return cfg


PROJECT_DIR = Path(config.get("project_dir", ".")).resolve()
BD_CFG_PATH = Path(config.get("bayesdream_config", "examples/gfi1b_cli_config_smk.yaml"))
if not BD_CFG_PATH.is_absolute():
    BD_CFG_PATH = (PROJECT_DIR / BD_CFG_PATH).resolve()

BD_CFG = _load_bayesdream_cfg(BD_CFG_PATH)
MODEL_CFG = BD_CFG.get("model") or {}
LABEL = MODEL_CFG.get("label")
if not LABEL:
    raise ValueError("model.label is required in bayesdream config")

OUTPUT_DIR = Path(MODEL_CFG.get("output_dir", "output"))
if not OUTPUT_DIR.is_absolute():
    OUTPUT_DIR = (PROJECT_DIR / OUTPUT_DIR).resolve()
RUN_DIR = OUTPUT_DIR / LABEL

EXEC_CFG = config.get("execution") or {}
MODE = str(EXEC_CFG.get("mode", "auto")).lower()
if MODE not in {"auto", "container", "local"}:
    raise ValueError(f"execution.mode must be one of auto/container/local, got: {MODE}")

APPTAINER_AVAILABLE = shutil.which("apptainer") is not None
if MODE == "local":
    USE_CONTAINER = False
elif MODE == "container":
    USE_CONTAINER = True
else:
    USE_CONTAINER = APPTAINER_AVAILABLE

PREFER_GPU = bool(EXEC_CFG.get("prefer_gpu", True))
GPU_AVAILABLE = _has_nvidia_gpu()
USE_GPU = USE_CONTAINER and PREFER_GPU and GPU_AVAILABLE

IMAGE_CPU = EXEC_CFG.get(
    "image_cpu",
    "oras://ghcr.io/statisticalbiotechnology/bayesdream-apptainer:cpu-amd64-latest",
)
IMAGE_GPU = EXEC_CFG.get(
    "image_gpu",
    "oras://ghcr.io/statisticalbiotechnology/bayesdream-apptainer:cuda-amd64-latest",
)
LOCAL_PYTHON = str(EXEC_CFG.get("local_python", "python"))

if USE_CONTAINER:
    CONTAINER_IMAGE = IMAGE_GPU if USE_GPU else IMAGE_CPU
    if not CONTAINER_IMAGE:
        raise ValueError("Container mode selected but no image configured")
    try:
        BD_CFG_REL = BD_CFG_PATH.relative_to(PROJECT_DIR).as_posix()
    except ValueError as e:
        raise ValueError(
            f"bayesdream_config must be inside project_dir for container mode. "
            f"project_dir={PROJECT_DIR}, bayesdream_config={BD_CFG_PATH}"
        ) from e
else:
    CONTAINER_IMAGE = None
    BD_CFG_REL = None

print(f"[snakemake] project_dir={PROJECT_DIR}")
print(f"[snakemake] bayesdream_config={BD_CFG_PATH}")
print(f"[snakemake] execution.mode={MODE}, use_container={USE_CONTAINER}, use_gpu={USE_GPU}")
if USE_CONTAINER:
    print(f"[snakemake] container_image={CONTAINER_IMAGE}")


def cli_cmd(subcommand: str) -> str:
    if USE_CONTAINER:
        bind_arg = shlex.quote(f"{PROJECT_DIR}:/work")
        image_arg = shlex.quote(CONTAINER_IMAGE)
        cfg_arg = shlex.quote(f"/work/{BD_CFG_REL}")
        nv_arg = "--nv " if USE_GPU else ""
        return (
            f"apptainer exec --cleanenv {nv_arg}--bind {bind_arg} {image_arg} "
            f"bash -lc \"cd /work && python -m bayesDREAM {subcommand} --config {cfg_arg}\""
        )

    py_arg = shlex.quote(LOCAL_PYTHON)
    proj_arg = shlex.quote(str(PROJECT_DIR))
    cfg_arg = shlex.quote(str(BD_CFG_PATH))
    return f"cd {proj_arg} && {py_arg} -m bayesDREAM {subcommand} --config {cfg_arg}"


rule all:
    input:
        str(RUN_DIR / "alpha_x_prefit.pt"),
        str(RUN_DIR / "posterior_samples_technical_gene.pt"),
        str(RUN_DIR / "x_true.pt"),
        str(RUN_DIR / "posterior_samples_cis.pt"),


rule fit_technical:
    input:
        str(BD_CFG_PATH),
    output:
        alpha_x=str(RUN_DIR / "alpha_x_prefit.pt"),
        tech_gene=str(RUN_DIR / "posterior_samples_technical_gene.pt"),
    log:
        str(RUN_DIR / ".snakemake_fit_technical.log"),
    params:
        run_dir=str(RUN_DIR),
        cmd=lambda wildcards: cli_cmd("fit-technical"),
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.run_dir}
        {params.cmd} 2>&1 | tee {log}
        """


rule fit_cis:
    input:
        cfg=str(BD_CFG_PATH),
        alpha_x=str(RUN_DIR / "alpha_x_prefit.pt"),
        tech_gene=str(RUN_DIR / "posterior_samples_technical_gene.pt"),
    output:
        x_true=str(RUN_DIR / "x_true.pt"),
        posterior_cis=str(RUN_DIR / "posterior_samples_cis.pt"),
    log:
        str(RUN_DIR / ".snakemake_fit_cis.log"),
    params:
        run_dir=str(RUN_DIR),
        cmd=lambda wildcards: cli_cmd("fit-cis"),
    shell:
        r"""
        set -euo pipefail
        mkdir -p {params.run_dir}
        {params.cmd} 2>&1 | tee {log}
        """
